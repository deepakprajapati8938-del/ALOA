# Ollama (Local - Priority 1 if OLLAMA_URL is set)
OLLAMA_URL=http://localhost:11434/v1/chat/completions
OLLAMA_MODEL=gemma4:e2b

# Llama.cpp / Generic Local (Priority 2)
LLAMA_CPP_URL=http://localhost:8080/v1/chat/completions
LOCAL_LLM_MODEL=gemma-4
LOCAL_LLM_API_KEY=no-key  # Change if your local server uses an API key

# OpenRouter (Priority 3)
OPENROUTER_API_KEY=your_openrouter_key_here

# Groq (Fail-safe)
GROQ_API_KEY=your_groq_key_here
