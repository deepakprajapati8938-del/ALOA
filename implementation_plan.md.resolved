│   ├── cpu_monitor.py         # CPU spike detection
│   ├── disk_inspector.py      # Disk usage & clutter scan
│   ├── startup_analyzer.py    # Startup program impact
│   ├── unused_apps.py         # Unused application detection
│   ├── bottleneck.py          # Performance bottleneck identification
│   └── suggestions.py         # Suggestion engine + optional execution
└── utils/
    ├── __init__.py
